          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="mlp" value="&lt;b&gt;Couche de fusion MLP&lt;/b&gt;&lt;br&gt;Combine les prédictions spatiales et waveform&lt;br&gt;&lt;font color=&quot;#999&quot;&gt;&lt;i&gt;(en cours de développement)&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontSize=11;shadow=0;dashed=1;dashPattern=8 4;strokeWidth=2;opacity=65;" vertex="1" parent="1">
          <mxGeometry x="250" y="760" width="340" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="out" value="&lt;b&gt;Prédiction finale&lt;/b&gt;&lt;br&gt;Classe de magnitude maximale par région/année&lt;br&gt;&lt;font color=&quot;#999&quot;&gt;&lt;i&gt;(en cours de développement)&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontSize=11;shadow=0;dashed=1;dashPattern=8 4;strokeWidth=2;fontColor=#666;opacity=65;" vertex="1" parent="1">
          <mxGeometry x="270" y="890" width="300" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="fe1" edge="1" parent="1" source="so" target="mlp" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeWidth=2;strokeColor=#999999;dashed=1;dashPattern=8 4;">
