<mxfile>
  <diagram name="SeiSM Architecture" id="seism">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="&lt;font style=&quot;font-size:20px&quot;&gt;&lt;b&gt;Architecture SeiSM&lt;/b&gt;&lt;/font&gt;&lt;br&gt;Prédiction sismique par SSM multi-branches" style="text;html=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="235" y="10" width="400" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="sp" value="&lt;b&gt;Branche spatiale&lt;/b&gt;" style="swimlane;startSize=30;fillColor=#EDF2FA;strokeColor=#6c8ebf;html=1;fontSize=14;fontStyle=1;rounded=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="80" width="460" height="620" as="geometry"/>
        </mxCell>
        <mxCell id="i1" value="&lt;b&gt;Catalogues sismiques&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-family:monospace&quot;&gt;(10, 65, 282)&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;i&gt;années × régions × descripteurs&lt;br&gt;65 = 64 locales + 1 globale&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;shadow=1;" vertex="1" parent="sp">
          <mxGeometry x="15" y="50" width="200" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="i2" value="&lt;b&gt;Cartes géologiques&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-family:monospace&quot;&gt;(10, 64, 50, 50, 5)&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;i&gt;années × régions × H × W × canaux&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;shadow=1;" vertex="1" parent="sp">
          <mxGeometry x="245" y="50" width="200" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="ce" value="&lt;b&gt;Encodeur de catalogue&lt;/b&gt;&lt;br&gt;4x FC + LeakyReLU&lt;br&gt;282-d → 32-d" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;shadow=1;" vertex="1" parent="sp">
          <mxGeometry x="20" y="170" width="190" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="me" value="&lt;b&gt;Encodeur de cartes&lt;/b&gt;&lt;br&gt;ResNet CNN&lt;br&gt;(5,50,50) → 32-d" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;shadow=1;" vertex="1" parent="sp">
          <mxGeometry x="250" y="170" width="190" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="sf" value="&lt;b&gt;Fusion des embeddings&lt;/b&gt;&lt;br&gt;Concaténation sur 64 regions&lt;br&gt;→ un seul token par pas de temps" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;shadow=1;" vertex="1" parent="sp">
          <mxGeometry x="80" y="300" width="300" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="sm" value="&lt;b&gt;Mamba SSM résiduel empilé&lt;/b&gt;&lt;br&gt;Modélisation de séquences temporelles" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;shadow=1;" vertex="1" parent="sp">
          <mxGeometry x="100" y="420" width="260" height="60" as="geometry"/>
