        <mxCell id="wb" value="&lt;b&gt;Branche Waveform&lt;/b&gt;" style="swimlane;startSize=30;fillColor=#FDF2F8;strokeColor=#9673a6;html=1;fontSize=14;fontStyle=1;rounded=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="80" width="300" height="620" as="geometry"/>
        </mxCell>
        <mxCell id="wi" value="&lt;b&gt;Forme d'onde sismique&lt;/b&gt;&lt;br&gt;Signal sismique brut" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;shadow=1;" vertex="1" parent="wb">
          <mxGeometry x="50" y="50" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="we" value="&lt;b&gt;Embedding de forme d'onde&lt;/b&gt;&lt;br&gt;CNN + Conv1D" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;shadow=1;" vertex="1" parent="wb">
